{
  "name": "@emisso/sii",
  "version": "0.1.0",
  "description": "TypeScript SDK for Chile's SII (Servicio de Impuestos Internos) tax authority integration",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:integration": "tsx scripts/test-auth.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sii",
    "chile",
    "tax",
    "dte",
    "factura",
    "boleta",
    "impuestos"
  ],
  "author": "Emisso <hello@emisso.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emisso-ai/emisso-sii"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "axios-retry": "^4.5.0",
    "crawlee": "^3.16.0",
    "fast-xml-parser": "^4.5.0",
    "node-forge": "^1.3.0",
    "playwright": "^1.58.2",
    "tough-cookie": "^6.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.0",
    "@types/tough-cookie": "^4.0.5",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
