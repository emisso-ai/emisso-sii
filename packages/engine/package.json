{
  "name": "@emisso/sii",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript SDK for Chile's SII (Servicio de Impuestos Internos) tax authority integration",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest --run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "sii",
    "chile",
    "tax",
    "dte",
    "factura",
    "boleta",
    "impuestos",
    "electronic-invoicing",
    "facturacion-electronica",
    "servicio-impuestos-internos",
    "nota-credito",
    "nota-debito",
    "guia-despacho",
    "xml-dte",
    "caf",
    "folio",
    "rcv",
    "registro-compra-venta",
    "certificado-digital",
    "p12",
    "pfx",
    "typescript",
    "sdk",
    "latin-america",
    "latam"
  ],
  "author": "Emisso <hello@emisso.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emisso-ai/emisso-sii",
    "directory": "packages/engine"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "axios-retry": "^4.5.0",
    "fast-xml-parser": "^4.5.0",
    "node-forge": "^1.3.0",
    "playwright-core": "^1.58.0",
    "tough-cookie": "^6.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "playwright": "^1.58.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.0",
    "@types/tough-cookie": "^4.0.5",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
