# Path to the .p12 / .pfx digital certificate issued by SII
SII_CERT_PATH=./certs/cert.p12

# Password for the digital certificate
SII_CERT_PASSWORD=

# SII environment: "certification" for testing, "production" for live
SII_ENV=certification

# Portal auth (clave tributaria) — used for DTE upload
SII_PORTAL_RUT=76123456-7
SII_PORTAL_PASSWORD=
